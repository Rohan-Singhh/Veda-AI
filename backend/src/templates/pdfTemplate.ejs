<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title><%= paper.title %></title>
  <style>
    body {
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      margin: 0;
      padding: 20px;
      color: #333;
    }
    .header {
      text-align: center;
      margin-bottom: 30px;
      border-bottom: 2px solid #333;
      padding-bottom: 20px;
    }
    .title {
      font-size: 24px;
      font-weight: bold;
      margin-bottom: 10px;
    }
    .meta {
      font-size: 14px;
      color: #555;
    }
    .student-info {
      display: flex;
      justify-content: space-between;
      margin-bottom: 30px;
    }
    .student-info div {
      flex: 1;
      margin: 0 10px;
      border-bottom: 1px solid #999;
      padding-bottom: 5px;
    }
    .student-info span {
      font-size: 12px;
      color: #666;
      text-transform: uppercase;
    }
    .section {
      margin-bottom: 30px;
    }
    .section-title {
      font-size: 18px;
      font-weight: bold;
      margin-bottom: 5px;
    }
    .section-instruction {
      font-size: 14px;
      font-style: italic;
      color: #666;
      margin-bottom: 15px;
    }
    .question {
      margin-bottom: 20px;
      display: flex;
    }
    .q-number {
      font-weight: bold;
      margin-right: 10px;
      width: 30px;
    }
    .q-content {
      flex: 1;
    }
    .q-text {
      margin-bottom: 10px;
    }
    .q-options {
      margin-left: 15px;
    }
    .q-option {
      margin-bottom: 5px;
    }
    .q-meta {
      font-size: 12px;
      color: #777;
      text-align: right;
      width: 80px;
    }
    .badge {
      display: inline-block;
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 10px;
      margin-right: 5px;
      background: #f0f0f0;
      border: 1px solid #ccc;
    }
  </style>
</head>
<body>
  <div class="header">
    <div class="title"><%= paper.title %></div>
    <div class="meta">
      Subject: <%= paper.subject %> | Topic: <%= paper.topic %><br>
      Duration: <%= paper.duration %> | Total Marks: <%= paper.totalMarks %>
    </div>
  </div>

  <div class="student-info">
    <div><span>Student Name</span></div>
    <div><span>Roll Number</span></div>
    <div><span>Section</span></div>
  </div>

  <% paper.sections.forEach(function(section) { %>
    <div class="section">
      <div class="section-title"><%= section.title %></div>
      <div class="section-instruction"><%= section.instruction %></div>
      
      <% section.questions.forEach(function(question) { %>
        <div class="question">
          <div class="q-number">Q<%= question.questionNumber %>.</div>
          <div class="q-content">
            <div class="q-text"><%= question.text %></div>
            <% if (question.options && question.options.length > 0) { %>
              <div class="q-options">
                <% question.options.forEach(function(opt) { %>
                  <div class="q-option"><%= opt %></div>
                <% }); %>
              </div>
            <% } %>
          </div>
          <div class="q-meta">
            <span class="badge"><%= question.difficulty %></span>
            <span>[<%= question.marks %>]</span>
          </div>
        </div>
      <% }); %>
    </div>
  <% }); %>
</body>
</html>
